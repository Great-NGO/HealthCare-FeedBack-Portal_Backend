generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Admin users who manage the system
model Admin {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password_hash          String?
  full_name              String?
  role                   AppRole   @default(admin)
  is_active              Boolean   @default(true)
  password_reset_token   String?
  password_reset_expires DateTime?
  created_at             DateTime  @default(now())
  created_by             String?
  creator                Admin?    @relation("AdminCreatedBy", fields: [created_by], references: [id])
  created_admins         Admin[]   @relation("AdminCreatedBy")

  @@index([email])
  @@index([password_reset_token])
  @@map("admins")
}

/// Main feedback submissions from users
model FeedbackSubmission {
  id                            String             @id @default(uuid())
  reference_id                  String             @unique
  anonymous                     Boolean            @default(false)
  reporter_name                 String?
  reporter_email                String?
  reporter_phone                String?
  reporter_type                 String?
  reporting_for_self            Boolean?
  reporter_relationship         String?
  reporter_organization         String?
  reporter_gender               String?
  reporter_age_range            String?
  reporter_disability_status    String?
  reporter_income_range         String?
  reporter_education_level      String?
  reporter_region               String?
  reporter_marital_status       String?
  reporter_geographic_setting   String?
  reporter_insurance_coverage   String?
  reporter_healthcare_frequency String?
  reporter_sexuality            String?
  patient_name                  String?
  patient_email                 String?
  patient_phone                 String?
  feedback_type                 FeedbackType
  facility_type                 String?
  facility_state                String?
  facility_lga                  String?
  facility_name                 String?
  incident_date                 DateTime?
  incident_time                 String?
  department                    String?
  location                      String?
  staff_involved                String?
  witnesses                     String?
  description                   String
  severity                      Int?
  issue_classification          String?
  issue_classification_other    String?
  life_threatening              String?
  needs_advocacy                String?
  advocacy_contact_name         String?
  advocacy_contact_phone        String?
  advocacy_contact_email        String?
  advocacy_contact_area         String?
  voice_message_url             String?
  voice_message_duration        Int?
  voice_transcription           String?
  voice_language                String?
  additional_comments           String?
  survey_token                  String?            @unique
  use_preference_anonymise      Boolean?
  use_preference_advocacy       Boolean?
  status                        FeedbackStatus     @default(new)
  admin_notes                   String?
  assigned_department           String?
  confirmation_email_sent       Boolean            @default(false)
  followup_email_sent           Boolean            @default(false)
  partner_id                    String?
  referral_session_id           String?
  referral_link_id              String?
  created_at                    DateTime           @default(now())
  updated_at                    DateTime           @updatedAt
  evidence                      FeedbackEvidence[]
  pending_entries               PendingEntry[]
  survey_response               SurveyResponse?
  partner                       Partner?           @relation(fields: [partner_id], references: [id])
  referral_session              ReferralSession?   @relation(fields: [referral_session_id], references: [id])
  referral_link                 PartnerReferralLink? @relation(fields: [referral_link_id], references: [id])
  referral_credit               ReferralCredit?

  @@index([reference_id])
  @@index([status])
  @@index([created_at])
  @@index([feedback_type])
  @@index([partner_id])
  @@index([referral_session_id])
  @@index([referral_link_id])
  @@map("feedback_submissions")
}

/// Partners that can receive referral credits
model Partner {
  id           String               @id @default(uuid())
  display_name String
  slug         String               @unique
  is_active    Boolean              @default(true)
  created_at   DateTime             @default(now())

  links         PartnerReferralLink[]
  credits       ReferralCredit[]
  feedback      FeedbackSubmission[]

  @@index([slug])
  @@index([is_active])
  @@map("partners")
}

/// Admin-defined time window for a referral campaign/session
model ReferralSession {
  id         String               @id @default(uuid())
  name       String
  starts_at  DateTime
  ends_at    DateTime
  is_active  Boolean              @default(true)
  created_at DateTime             @default(now())

  links    PartnerReferralLink[]
  credits  ReferralCredit[]
  feedback FeedbackSubmission[]

  @@index([starts_at])
  @@index([ends_at])
  @@index([is_active])
  @@map("referral_sessions")
}

/// A partner-specific referral link for a given session
/// Store only a hash of the token to avoid leaking raw URLs if DB is compromised.
model PartnerReferralLink {
  id           String          @id @default(uuid())
  partner_id   String
  session_id   String
  token_hash   String          @unique
  token_prefix String
  revoked_at   DateTime?
  created_at   DateTime        @default(now())

  partner Partner        @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  session ReferralSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  feedback FeedbackSubmission[]

  @@index([partner_id])
  @@index([session_id])
  @@index([revoked_at])
  @@map("partner_referral_links")
}

/// A single counted credit (deduped by email_hash per partner per session)
model ReferralCredit {
  id         String          @id @default(uuid())
  partner_id String
  session_id String
  email_hash String
  feedback_id String         @unique
  created_at DateTime        @default(now())

  partner  Partner         @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  session  ReferralSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  feedback FeedbackSubmission @relation(fields: [feedback_id], references: [id], onDelete: Cascade)

  @@unique([partner_id, session_id, email_hash])
  @@index([partner_id])
  @@index([session_id])
  @@map("referral_credits")
}

/// Evidence/attachments for feedback
model FeedbackEvidence {
  id          String             @id @default(uuid())
  feedback_id String
  file_name   String
  file_url    String
  file_type   String?
  file_size   Int?
  created_at  DateTime           @default(now())
  feedback    FeedbackSubmission @relation(fields: [feedback_id], references: [id], onDelete: Cascade)

  @@index([feedback_id])
  @@map("feedback_evidence")
}

/// Survey responses linked to feedback
model SurveyResponse {
  id                   String              @id @default(uuid())
  feedback_id          String?             @unique
  overall_satisfaction Int?
  staff_friendliness   Int?
  communication        Int?
  cleanliness          Int?
  wait_time            Int?
  would_recommend      Boolean?
  comments             String?
  created_at           DateTime            @default(now())
  feedback             FeedbackSubmission? @relation(fields: [feedback_id], references: [id])

  @@map("survey_responses")
}

/// Custom facilities added by users
model CustomFacility {
  id            String         @id @default(uuid())
  name          String
  facility_type String
  state         String
  lga           String
  status        FacilityStatus @default(pending)
  created_at    DateTime       @default(now())
  approved_at   DateTime?
  approved_by   String?

  @@index([status])
  @@index([state, lga])
  @@map("custom_facilities")
}

/// Pending entries for custom values (sexuality, etc.)
model PendingEntry {
  id            String              @id @default(uuid())
  entry_type    String
  value         String
  feedback_id   String?
  facility_type String?
  state         String?
  lga           String?
  status        PendingEntryStatus  @default(pending)
  created_at    DateTime            @default(now())
  approved_at   DateTime?
  approved_by   String?
  feedback      FeedbackSubmission? @relation(fields: [feedback_id], references: [id])

  @@index([status])
  @@index([entry_type])
  @@map("pending_entries")
}

/// User role assignments (legacy, if needed)
model UserRole {
  id         String   @id @default(uuid())
  user_id    String
  role       AppRole
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("user_roles")
}

/// Recognized NGOs for reporter organization dropdown (seeded from xlsx)
model RecognizedNgo {
  id         String   @id @default(uuid())
  name       String   @unique
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@index([name])
  @@map("recognized_ngos")
}

/// Health facilities from GRID3 Nigeria dataset (~51,000 facilities)
model HealthFacility {
  id             String                @id @default(uuid())
  state          String
  lga            String
  facility_name  String
  ownership_type FacilityOwnershipType @default(unknown)
  created_at     DateTime              @default(now())
  is_custom      Boolean               @default(false)

  @@index([state])
  @@index([state, lga])
  @@index([state, lga, facility_name])
  @@map("health_facilities")
}

enum AppRole {
  admin
  moderator
  user
  super_admin
}

enum FeedbackStatus {
  new
  in_review
  resolved
  closed
}

enum FeedbackType {
  complaint
  concern
  compliment
  safety_incident
  comment
}

enum PendingEntryStatus {
  pending
  approved
  rejected
}

enum FacilityStatus {
  pending
  approved
  rejected
}

enum FacilityOwnershipType {
  federal
  state
  private
  unknown
}
